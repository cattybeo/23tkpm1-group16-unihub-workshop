{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "scripts/bootstrap-admin.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/app.ts",
    "src/workers",
    "src/middleware/error-handler.ts",
    "src/modules/ai-summary",
    "src/modules/catalog",
    "src/modules/checkin",
    "src/modules/datasync",
    "src/modules/payment",
    "src/modules/registration"
  ]
}
